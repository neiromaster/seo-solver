{
  "name": "seo-solver",
  "version": "0.0.3",
  "description": "SEO audit and comparison CLI tool",
  "type": "module",
  "bin": {
    "seo-solver": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "tsx src/index.ts",
    "build": "pnpm --filter seo-solver^... build && tsup --config tsup.config.ts",
    "prepack": "pnpm run build",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@seo-solver/compare": "workspace:*",
    "@seo-solver/extract": "workspace:*",
    "@seo-solver/fetch": "workspace:*",
    "@seo-solver/report": "workspace:*",
    "@seo-solver/types": "workspace:*",
    "@seo-solver/validate": "workspace:*",
    "cmd-ts": "^0.15.0"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "author": "Maxim (neiromaster) Gavrilenko",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neiromaster/seo-solver.git",
    "directory": "apps/seo-solver"
  },
  "bugs": {
    "url": "https://github.com/neiromaster/seo-solver/issues"
  },
  "homepage": "https://github.com/neiromaster/seo-solver#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
