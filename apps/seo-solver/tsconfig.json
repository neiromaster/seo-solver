{
  "extends": "../../packages/typescript-config/base.json",
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@seo-solver/compare": [
        "../../packages/compare/src/index.ts"
      ],
      "@seo-solver/extract": [
        "../../packages/extract/src/index.ts"
      ],
      "@seo-solver/fetch": [
        "../../packages/fetch/src/index.ts"
      ],
      "@seo-solver/report": [
        "../../packages/report/src/index.ts"
      ],
      "@seo-solver/types": [
        "../../packages/types/src/index.ts"
      ],
      "@seo-solver/validate": [
        "../../packages/validate/src/index.ts"
      ]
    }
  },
  "include": [
    "../../packages/types/src/**/*.ts",
    "../../packages/fetch/src/**/*.ts",
    "../../packages/extract/src/**/*.ts",
    "../../packages/validate/src/**/*.ts",
    "../../packages/compare/src/**/*.ts",
    "../../packages/report/src/**/*.ts",
    "src/**/*.ts",
    "__tests__/**/*.ts",
    "vitest.config.ts"
  ],
  "exclude": [
    "dist"
  ]
}
