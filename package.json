{
  "name": "seo-solver",
  "version": "0.0.1",
  "description": "CLI tool for comparing and validating structured data (JSON-LD, OpenGraph) for SEO",
  "module": "dist/index.js",
  "main": "dist/index.js",
  "type": "module",
  "bin": "./dist/index.js",
  "exports": "./dist/index.js",
  "scripts": {
    "start": "bun run src/index.ts",
    "build": "tsup",
    "lint": "biome check . && dprint check",
    "format": "biome check --write --unsafe . && dprint fmt",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@adobe/structured-data-validator": "^1.7.0",
    "cmd-ts": "^0.15.0",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/node": "22",
    "dprint": "^0.53.0",
    "lefthook": "^2.1.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "seo",
    "schema",
    "json-ld",
    "opengraph",
    "structured-data",
    "validator",
    "comparison",
    "cli",
    "solver"
  ],
  "author": "Maxim (neiromaster) Gavrilenko",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neiromaster/seo-solver.git"
  },
  "bugs": {
    "url": "https://github.com/neiromaster/seo-solver/issues"
  },
  "homepage": "https://github.com/neiromaster/seo-solver#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
