{
  "name": "seo-solver-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "scripts": {
    "build": "pnpm -r --workspace-concurrency=1 --if-present build",
    "changeset": "changeset",
    "consistency:check": "pnpm exec tsx scripts/check-monorepo-consistency.ts",
    "lint": "pnpm exec biome check . && pnpm exec dprint check",
    "format": "pnpm exec biome check --write --unsafe . && pnpm exec dprint fmt",
    "typecheck": "pnpm exec tsc -p tsconfig.test.json --noEmit && pnpm exec tsc -p scripts/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "pnpm --filter seo-solver test:coverage",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@vitest/coverage-v8": "^4.1.2",
    "dprint": "^0.53.2",
    "lefthook": "^2.1.4",
    "tsdown": "^0.21.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
