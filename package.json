{
  "name": "seo-solver-workspace",
  "private": true,
  "packageManager": "pnpm@8.14.1",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "lint": "pnpm exec biome check . && pnpm exec dprint check",
    "format": "pnpm exec biome check --write --unsafe . && pnpm exec dprint fmt",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "test:coverage": "pnpm --filter seo-solver test:coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@vitest/coverage-v8": "^4.1.2",
    "dprint": "^0.53.2",
    "lefthook": "^2.1.4",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  }
}
