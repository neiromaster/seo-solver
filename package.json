{
  "name": "seo-solver-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r --workspace-concurrency=1 --if-present build",
    "changeset": "changeset",
    "consistency:check": "pnpm exec tsx scripts/check-monorepo-consistency.ts",
    "lint": "pnpm exec biome check . && pnpm exec dprint check",
    "format": "pnpm exec biome check --write --unsafe . && pnpm exec dprint fmt",
    "typecheck": "pnpm exec tsc -b tsconfig.test.json",
    "test": "vitest run",
    "test:coverage": "pnpm --filter seo-solver test:coverage",
    "version-packages": "changeset version && pnpm install --lockfile-only",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.19.19",
    "@vitest/coverage-v8": "^4.1.6",
    "dprint": "^0.54.0",
    "lefthook": "^2.1.6",
    "tsdown": "^0.22.0",
    "tsx": "^4.22.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
}
