{
  "name": "schema-diff",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/index.ts",
    "build": "tsup",
    "lint": "biome check . && dprint check",
    "format": "biome check --write --unsafe . && dprint fmt",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@adobe/structured-data-validator": "^1.7.0",
    "playwright": "latest"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "dprint": "^0.53.0",
    "lefthook": "^2.1.4",
    "tsup": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
