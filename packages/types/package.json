{
  "name": "@seo-solver/types",
  "version": "0.0.0",
  "type": "module",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./fetch": {
      "types": "./dist/fetch.d.ts",
      "import": "./dist/fetch.js"
    },
    "./extract": {
      "types": "./dist/extract.d.ts",
      "import": "./dist/extract.js"
    },
    "./extract-advanced": {
      "types": "./dist/extract-advanced.d.ts",
      "import": "./dist/extract-advanced.js"
    },
    "./compare": {
      "types": "./dist/compare.d.ts",
      "import": "./dist/compare.js"
    },
    "./compare-advanced": {
      "types": "./dist/compare-advanced.d.ts",
      "import": "./dist/compare-advanced.js"
    },
    "./validate": {
      "types": "./dist/validate.d.ts",
      "import": "./dist/validate.js"
    },
    "./validate-advanced": {
      "types": "./dist/validate-advanced.d.ts",
      "import": "./dist/validate-advanced.js"
    },
    "./report": {
      "types": "./dist/report.d.ts",
      "import": "./dist/report.js"
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts && tsc --project tsconfig.build.json",
    "prepack": "pnpm run build",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  }
}
