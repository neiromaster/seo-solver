{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@seo-solver/fetch": [
        "../fetch/dist/index.d.ts"
      ],
      "@seo-solver/fetch/advanced": [
        "../fetch/dist/advanced.d.ts"
      ],
      "@seo-solver/types": [
        "../types/dist/index.d.ts"
      ],
      "@seo-solver/types/*": [
        "../types/dist/*.d.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "dist",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/test-support/**/*.ts",
    "vitest.config.ts"
  ]
}
