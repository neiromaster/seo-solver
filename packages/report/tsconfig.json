{
  "extends": "../typescript-config/node-lib.json",
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@seo-solver/types": [
        "../types/src/index.ts"
      ],
      "@seo-solver/types/*": [
        "../types/src/*.ts"
      ]
    }
  },
  "include": [
    "../types/src/**/*.ts",
    "src/**/*.ts",
    "__tests__/**/*.ts",
    "vitest.config.ts"
  ],
  "exclude": [
    "dist"
  ]
}
